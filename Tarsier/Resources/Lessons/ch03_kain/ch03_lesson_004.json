{"_meta":{"schema_version":"0.7","last_updated":"2026-03-19","notes":"Ch3 Review 1. Covers 024-026."},"lesson_id":"ch03_004","title":"Review","subtitle":"Eating, Cooking, Drinking","chapter_id":"ch03","chapter_title":"Food","position_in_chapter":4,"difficulty":"beginner","lesson_type":"review","total_sessions":1,"sessions":[{"session_id":"ch03_004_s1","session_number":1,"title":"Review","cards":[{"card_id":"ch03_004_s1_q1","type":"quiz","quiz_type":"image_match","prompt":"Match root to verb:","pairs":[{"left":"kain","right":"kumain (ate)"},{"left":"luto","right":"nagluto (cooked)"},{"left":"inom","right":"uminom (drank)"},{"left":"luto","right":"magluto (will cook)"}],"explanation":"kain → kumain (um-), luto → magluto/nagluto (mag-/nag-), inom → uminom (um-)."},{"card_id":"ch03_004_s1_q2","type":"quiz","quiz_type":"sentence_build","character":"lola","prompt":"Ask someone: 'Have you eaten yet?'","source_text":"","correct_order":["Kumain","ka","na","ba"],"distractors":["ako","po","ko"],"explanation":"Kumain ka na ba? The Filipino greeting."},{"card_id":"ch03_004_s1_q3","type":"quiz","quiz_type":"fill_in_blank","character":"stranger","source_text":"I cooked. (Past tense of luto)","prompt":"___ ako.","correct_answers":["Nagluto","nagluto"],"explanation":"Nagluto = cooked. nag- = past tense."},{"card_id":"ch03_004_s1_q4","type":"quiz","quiz_type":"multiple_choice","character":"stranger","source_text":"'Uminom ka ba ng tubig?'","prompt":"What are they asking?","options":["Did you drink water?","Do you want water?","Where is the water?","Is the water cold?"],"correct_answer":0,"explanation":"Uminom ka ba = did you drink? ng tubig = water. Ba = question.","shuffle_options":true},{"card_id":"ch03_004_s1_q5","type":"quiz","quiz_type":"multiple_choice","character":"stranger","source_text":"Which is the correct past tense?","prompt":"mag- becomes:","options":["mum-","um-","nag-","pag-"],"correct_answer":2,"explanation":"mag- (future/present) → nag- (past). Magluto → Nagluto.","