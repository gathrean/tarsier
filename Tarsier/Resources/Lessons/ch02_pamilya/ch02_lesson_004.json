iz","quiz_type":"fill_in_blank","character":"stranger","source_text":"Jun is your older brother. Address him:","prompt":"___ Jun","correct_answers":["Kuya","kuya"],"explanation":"Kuya = older brother. Before the name."},{"card_id":"ch02_004_s1_q7","type":"quiz","quiz_type":"multiple_choice","character":"stranger","source_text":"Your nanay calls: 'Anak, kumain ka na!'","prompt":"What does anak mean here?","options":["Friend","Child (you)","Sibling","Older sister"],"correct_answer":1,"explanation":"Anak = child. Your nanay is calling you to eat.","shuffle_options":true}]}],"vocabulary":[],"wrong_answer_tracking":{"behaviour":"Wrong answers go to back of current session queue.","track_wrong_count":true,"wrong_count_usage":"Feed to Gemini."},"completion_reward":{"xp":20,"alam_mo_ba":["In some Filipino families, even pets get called 'bunso.'","Ate and kuya are so ingrained that some Filipino-Americans who don't speak Tagalog still use them in English conversation."]},"gamification":{"xp_per_lesson":20,"hearts_per_wrong_answer":1,"streak_eligible":true,"replay":{"allowed":true,"xp_on_replay":0}}}
