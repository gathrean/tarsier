{"_meta":{"schema_version":"0.7","last_updated":"2026-03-19","notes":"Ch2 Review 3. Covers ch02_008-009."},"lesson_id":"ch02_010","title":"Review","subtitle":"Love and Home","chapter_id":"ch02","chapter_title":"Family","position_in_chapter":10,"difficulty":"beginner","lesson_type":"review","total_sessions":1,"sessions":[{"session_id":"ch02_010_s1","session_number":1,"title":"Review","cards":[{"card_id":"ch02_010_s1_q1","type":"quiz","quiz_type":"multiple_choice","character":"stranger","source_text":"'Mahal ang bag!' your friend says.","prompt":"What do they mean?","options":["I love the bag!","The bag is expensive!","Buy me the bag!","The bag is beautiful!"],"correct_answer":1,"explanation":"Mahal + ang [thing] = expensive.","shuffle_options":true},{"card_id":"ch02_010_s1_q2","type":"quiz","quiz_type":"fill_in_blank","character":"stranger","source_text":"Say 'I love you' in Tagalog:","prompt":"Mahal ___","correct_answers":["kita","Kita"],"explanation":"Mahal kita = I love you."},{"card_id":"ch02_010_s1_q3","type":"quiz","quiz_type":"multiple_choice","character":"stranger","source_text":"Bahay vs Tahanan:","prompt":"Which one means the physical building?","options":["Bahay","Tahanan","Pamilya","Both"],"correct_answer":0,"explanation":"Bahay = house (building). Tahanan = home (feeling).","shuffle_options":true},{"card_id":"ch02_010_s1_q4","type":"quiz","quiz_type":"sentence_build","character":"stranger","prompt":"Tell someone: 'I love Mom.'","source_text":"","correct_order":["Mahal","ko","si","Nanay"],"distractors":["kita","mo","ang"],"explanation":"Mahal ko si Nanay. Ko = I/my, si = name marker."},{"card_id":"ch02_010_s1_q5","type":"quiz","quiz_type":"fill_in_blank","character":"stranger","source_text":"How do you say 'my family'?","prompt":"___ ko","correct_answers":["Pamilya","pamilya"],"explanation":"Pamilya ko = my family."},{"card_id":"ch02_010_s1_q6","type":"quiz","quiz_type":"multiple_choice","character":"lola","source_text":"Lola says: 'Tahanan ko, tahanan mo!'","prompt":"What does she mean?","options":["My home is your home!","Your home is far!","Go home!","I miss home!"],"correct_answer":0,"explanation":"Tahanan ko, tahanan mo = My home is your home. Filipino hospitality.","shuffle_options":true}]}],"vocabulary":[],"wrong_answer_tracking":{"behaviour":"Wrong answers go to back of current session queue.","track_wrong_count":true,"wrong_count_usage":"Feed to Gemini."},"completion_reward":{"xp":20,"alam_mo_ba":["When a Filipino says 'mahal kita,' they mean it. It's not thrown around casually like 'love ya' in English.","The Filipino concept of family extends far beyond blood. Neighbours, family friends, and even coworkers can become honorary tita/tito."]},"gamification":{"xp_per_lesson":20,"hearts_per_wrong_answer":1,"streak_eligible":true,"replay":{"allowed":true,"xp_on_replay":0}}}
